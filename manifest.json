{
  "name": "ts-template",
  "description": "ts-template for UbiquityOS plugins.",
  "ubiquity:listeners": ["issue_comment.created", "pull_request_review_comment.created"],
  "commands": {
    "config": {
      "ubiquity:example": "/config <scope> <editor_instruction>",
      "description": "config command with scope and editor_instruction arguments."
    }
  },
  "configuration": {
    "default": {},
    "type": "object",
    "properties": {
      "baseUrl": {
        "default": "https://openrouter.ai/api/v1",
        "type": "string"
      },
      "parserPath": {
        "default": "https://github.com/ShivTestOrg/ubiquity-os-kernel.git",
        "type": "string"
      },
      "configPath": {
        "default": ".github/.ubiquity-os.config.yml",
        "type": "string"
      },
      "devConfigPath": {
        "default": ".github/.ubiquity-os.config.dev.yml",
        "type": "string"
      },
      "defaultTargets": {
        "default": [
          {
            "name": "https://github.com/ShivTestOrg/test-public.git",
            "branch": "main"
          }
        ],
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "default": "https://github.com/ShivTestOrg/.ubiquity-os.git",
              "type": "string"
            },
            "branch": {
              "default": "main",
              "type": "string"
            },
            "type": {
              "default": "main",
              "anyOf": [
                {
                  "const": "main",
                  "type": "string"
                },
                {
                  "const": "dev",
                  "type": "string"
                }
              ]
            }
          }
        }
      }
    }
  }
}
