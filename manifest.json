{
  "name": "ts-template",
  "description": "ts-template for UbiquityOS plugins.",
  "ubiquity:listeners": ["issue_comment.created", "pull_request_review_comment.created"],
  "commands": {
    "hello": {
      "ubiquity:example": "/hello argument",
      "description": "Hello command with an argument."
    }
  },
  "configuration": {
    "default": {},
    "type": "object",
    "properties": {
      "parserPath": {
        "default": "https://github.com/ubiquity-os/ubiquity-os-kernel.git",
        "type": "string"
      },
      "configPath": {
        "default": ".github/.ubiquity-os.config.yml",
        "type": "string"
      },
      "devConfigPath": {
        "default": ".github/.ubiquity-os.config.dev.yml",
        "type": "string"
      },
      "defaultTargets": {
        "default": [
          {
            "name": "https://github.com/ubiquity/.ubiquity-os.git",
            "branch": "main"
          },
          {
            "name": "https://github.com/ubiquity-os/.ubiquity-os.git",
            "branch": "main"
          },
          {
            "name": "https://github.com/ubiquity-os-marketplace/.ubiquity-os.git",
            "branch": "main"
          }
        ],
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "default": "https://github.com/ubiquity/.ubiquity-os.git",
              "type": "string"
            },
            "branch": {
              "default": "main",
              "type": "string"
            },
            "type": {
              "default": "main",
              "anyOf": [
                {
                  "const": "main",
                  "type": "string"
                },
                {
                  "const": "dev",
                  "type": "string"
                }
              ]
            }
          }
        }
      }
    }
  }
}
